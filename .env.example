# Copy this file to .env and fill in values as needed.
# The app works without any of these — they are all optional.

# MongoDB (default: local Docker on port 27017)
MONGO_URL=mongodb://localhost:27017
DB_NAME=behavioral_bot

# Backend API URL seen by the Next.js frontend (default: localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000
